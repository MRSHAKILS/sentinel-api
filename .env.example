# Copy to .env for local runs. Names only — never commit real secrets.

# Port the service binds to (must bind 0.0.0.0 in container).
PORT=8000

# Max request body size in bytes (DoS guard). Default 262144 (256 KB).
MAX_BODY_BYTES=262144

# ---- Hybrid LLM enrichment (optional) ----
# When false, the service runs as a pure deterministic rule engine.
# The reasoning, routing, and safety guarantees stay rule-based either way;
# the LLM only assists language understanding and reply drafting, and every
# LLM output is validated + safety-scrubbed by code before it is returned.
USE_LLM=false
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=
LLM_TIMEOUT_SECONDS=4.5

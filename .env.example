# Copy to .env for local runs. Names only — never commit real secrets.

# Port the service binds to (must bind 0.0.0.0 in container).
PORT=8000

# Max request body size in bytes (DoS guard). Default 262144 (256 KB).
MAX_BODY_BYTES=262144

# Optional LLM polish for customer_reply/agent_summary. Default off.
# The reasoning, routing, and safety remain rule-based regardless.
USE_LLM=false
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-haiku-4-5
